# Mapbox GL JS access token — powers the live fleet-tracking map at /live.
# Get a free token at https://account.mapbox.com/access-tokens/
# Exposed to the client via runtimeConfig.public.mapboxToken (see nuxt.config.ts).
# Optional: every other screen runs on mock data and works without it.
MAPBOX_ACCESS_TOKEN=pk.your_mapbox_access_token_here
